{
  "name": "youtube-color-analyzer",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "description": "Extension Chrome locale pour analyser la colorimétrie d'une vidéo YouTube.",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch --mode development",
    "ui:preview": "vite --host 127.0.0.1",
    "site:build": "node website/build.mjs && node website/check.mjs",
    "assets:store": "node scripts/generate-store-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "package:store": "pnpm build && pnpm verify:dist && node scripts/package-store.mjs",
    "verify:dist": "node scripts/verify-release-build.mjs",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm verify:dist && pnpm site:build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
